# Optional environment overrides only. MILLIE does not require a .env file.
MILLIE_DB=.private/local/millie.sqlite
MILLIE_DATA_DIR=.private/local/data
MILLIE_SETTINGS=.private/local/millie.settings
MILLIE_PROFILES_DIR=.private/local/profiles
MILLIE_WEB_DIR=web/dist
MILLIE_HOST=0.0.0.0
MILLIE_PORT=22001
# Leave unset for HTTP development. Set both paths to enable direct HTTPS.
# MILLIE_TLS_CERT=.private/local/tls/dev.crt
# MILLIE_TLS_KEY=.private/local/tls/dev.key
